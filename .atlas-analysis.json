  "keyFeatures": [
    "Multi-location inventory management with real-time stock tracking",
    "Complete request workflow with traceability from creation to receipt",
    "Technician movement tracking with load/unload operations",
    "Warranty management with photographic evidence and approval workflow",
    "Physical inventory auditing with system vs actual count reconciliation",
    "Scooter order tracking with multi-level status updates",
    "Role-based access control with granular permissions",
    "Bulk spare parts import from Excel files",
    "Real-time notifications and stock alerts",
    "Feature-Sliced Design architecture for scalability"
  ],
  "publicApiSurface": [
    "InventoryItem - Core inventory entity with stock tracking",
    "RequestHistoryItem - Request workflow tracking",
    "Guarantee - Warranty management entity",
    "CartItem - Shopping cart for multi-item requests",
    "TimelineEvent - Movement history and audit trail",
    "useInventory() - Paginated inventory queries",
    "useRequests() - Request management hooks",
    "useGuarantees() - Warranty tracking hooks",
    "supabase - Configured Supabase client",
    "AutocompleteInput - Spare parts search component",
    "ProtectedRoute - Authentication wrapper",
    "useUserStore() - User state management",
    "useRecordsStore() - Records state management"
  ]
